# JC Brick & Blocklaying — environment variables
# Copy to .env.local and fill in. Never commit real values.

# Public site URL (used for canonicals, sitemap, schema)
NEXT_PUBLIC_SITE_URL=https://jcbricklaying.com.au

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX) — leave blank to disable analytics
NEXT_PUBLIC_GA_ID=

# Google Ads conversion (format AW-XXXXXXXXX/AbCdEfGhIjKlMnOpQr) — fires on /thank-you
NEXT_PUBLIC_GOOGLE_ADS_SEND_TO=

# GoHighLevel CRM lead capture endpoint (server-side) — provided by BPC
GHL_FORM_ENDPOINT=

# CRM tracking phone number once provisioned (display format), falls back to personal mobile
# NEXT_PUBLIC_CRM_PHONE=
