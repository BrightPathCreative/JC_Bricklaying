# JC Brick & Blocklaying — environment variables
# Copy to .env.local and fill in. Never commit real values.

# Public site URL (canonical host — must match your live domain)
NEXT_PUBLIC_SITE_URL=https://www.jcbricklaying.com.au

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX) — leave blank to disable analytics
NEXT_PUBLIC_GA_ID=

# Google Ads conversion (format AW-XXXXXXXXX/AbCdEfGhIjKlMnOpQr) — fires on /thank-you
NEXT_PUBLIC_GOOGLE_ADS_SEND_TO=
